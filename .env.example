# Backend Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8036

# Frontend Configuration
FRONTEND_PORT=8018

# Application Modes
# Set to 'true' to use local SQLite and local mock S3 storage folder without AWS
LOCAL_MODE=true

# Database (PostgreSQL) Config - Used if LOCAL_MODE=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bikesharing
DB_USER=postgres
DB_PASSWORD=postgres

# AWS Credentials and S3 Configuration - Used if LOCAL_MODE=false
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=bike-sharing-data
